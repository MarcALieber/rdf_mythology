  skos:exactMatch wd:Q182837;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  p:nativeTerm "Πολος";
  skos:definition "one of the elder Titanes (Titans),He and his brothers conspired against their father";
  skos:inScheme sch:GreekMythCharacter .

gim:Phoebe rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
