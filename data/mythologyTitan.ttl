gim:Hyperion rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:prefLabel "Hyperion"@en ;
  skos:prefLabel "Hypérion"@fr ;
  skos:exactMatch wd:Q179209;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  skos:definition "the Titan god of heavenly light";
  skos:inScheme sch:GreekMythCharacter .

gim:Iapetos rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:prefLabel "Iapetos"@en ;
  skos:prefLabel "Japet"@fr ;
  skos:exactMatch wd:Q179543;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  skos:definition "one of the elder Titanes";
  skos:inScheme sch:GreekMythCharacter .
  
gim:Oceanus rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:prefLabel "Oceanus"@en ;
  skos:altLabel "Okeanos"@en ;
  skos:prefLabel "Océan"@fr ;
  skos:exactMatch wd:Q161419;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  skos:definition "the primordial Titan god of the great, earth-encircling River Okeanos, font of all of the earth's fresh-water - rivers, wells, springs and rain-clouds";
  skos:inScheme sch:GreekMythCharacter .

gim:Themis rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:prefLabel "Themis"@en ;
  skos:prefLabel "Thémis"@fr ;
  skos:exactMatch wd:Q159168;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  skos:definition "in ancient Greek mythology, a titaness, the personification of divine order, fairness, law, natural law, and custom, whose symbols are the scales of justice";
  skos:inScheme sch:GreekMythCharacter .
  
gim:Coeus rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:prefLabel "Coeus"@en ;
  skos:prefLabel "Coéos"@fr ;
