gim:Rhea rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:definition "RHEIA (Rhea) was the Titanis (Titaness) mother of the gods, and goddess of female fertility, motherhood, and generation. Her name means flow and ease. As the wife of Kronos (Cronus, Time), she represented the eternal flow of time and generations; as the great Mother (Meter Megale), the flow was menstrual blood, birth waters, and milk"@en ;
  skos:inScheme sch:GreekMythCharacter ;
  skos:prefLabel "Rhea"@en, "Rhéa"@fr ;
  skos:exactMatch wd:Q108419;
  p:hasFather gim:Uranus ;
  p:hasMother gim:Gaea ;
  p:hasGender :female ;
  p:hasRomanCounterpart rim:Ops ;
  p:livesIn geo:Tartarus, geo:Elysium .

gim:Mnemosyne rdf:type owl:NamedIndividual,:Uranids, skos:Concept;
  skos:definition "the Titan goddess of memory and remembrance and the inventress of language and words"@en ;
  skos:inScheme sch:GreekMythCharacter ;
  skos:prefLabel "Mnemosyne"@en, "Mnémosyne"@fr ;
  skos:exactMatch wd:Q102884;
  p:hasFather gim:Uranus ;
  p:hasMother gim:Gaea ;
  p:nativeTerm "Μνημοσυνη";
  p:hasGender :female .
  
gim:Cronus rdf:type owl:NamedIndividual,:Uranids, :PersonifiedConcepts, skos:Concept;
  skos:prefLabel "Cronus"@en ;
  skos:prefLabel "Cronos"@fr ;
  skos:altLabel "Kronos"@en ;
  skos:exactMatch wd:Q44204;
  p:hasFather gim:Uranus ;  
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  p:nativeTerm "Κρονος";
  p:hasRomanCounterpart rim:Saturn ;
  skos:definition "the King of the Titanes and the god of time, in particular time when viewed as a destructive, all-devouring force";
  p:hasTheoiSource "https://www.theoi.com/Titan/TitanKronos.html" ;
  skos:inScheme sch:GreekMythCharacter .

gim:Kronos a skos:Concept, :protogenos, :PersonifiedConcepts ;
  skos:definition "KRONOS (Cronus) was the King of the Titanes and the god of time, in particular time when viewed as a destructive, all-devouring force."@en ;
  skos:inScheme sch:GreekMythCharacter ;
  skos:prefLabel "Chronos"@en, "Chronos"@fr ;
  skos:altLabel "Kronos"@en,"Cronus"@en ;
  p:nativeTerm "Χρόνος";
  p:hasFather gim:Uranus ;
  p:hasMother gim:Gaea ;
  p:hasGender :male ;
  skos:exactMatch wd:Q272918;
  p:livesIn geo:Tartarus, geo:Elysium .
  	  
