sy:Gorgoneion
  rdf:type owl:NamedIndividual, :Symbol, skos:Concept;
  skos:prefLabel "Gorgoneion"@en ;
  skos:prefLabel "Gorgoneion"@fr ;
  skos:definition "the head of the gorgon" .

sy:Bow
  rdf:type owl:NamedIndividual, :Symbol, skos:Concept;
  skos:prefLabel "Bow"@en ;
  skos:prefLabel "Arc"@fr ;
  skos:definition "un arc" .

sy:Aegis
  rdf:type owl:NamedIndividual, :Symbol, skos:Concept;
  skos:prefLabel "Aegis"@en ;
  skos:prefLabel "égide"@fr ;
  skos:exactMatch wd:Q190662;
  skos:definition "device carried by Athena and Zeus, variously interpreted as an animal skin or a shield and sometimes featuring the head of a Gorgon" .
    
sy:Lyre
  rdf:type owl:NamedIndividual, :Symbol, skos:Concept;
  skos:prefLabel "Lyre"@en ;
  skos:prefLabel "Lyre"@fr ;
  skos:exactMatch wd:Q201129;
  skos:definition "string instrument from Greek classical antiquity" .  

  

