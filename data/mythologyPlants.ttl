@prefix : <http://www.semanticweb.org/ontologies/mythologies#> .
@prefix sch: <http://www.semanticweb.org/mythologies/scheme/> .
@prefix m: <http://www.semanticweb.org/mythologies/class#> .
@prefix p: <http://www.semanticweb.org/mythologies/property#> .
@prefix gim: <http://www.semanticweb.org/mythologies/greek/immortal/> .
@prefix gmo: <http://www.semanticweb.org/mythologies/greek/mortal/> .
@prefix pl: <http://www.semanticweb.org/mythologies/plant/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix wd: <http://www.wikidata.org/entity/> .

pl:Laurel a owl:NamedIndividual ,skos:Concept, :sacredPlant ;
  skos:inScheme sch:SacredThing ;
  skos:prefLabel "Laurel"@en, "Laurier"@fr ;
  skos:exactMatch wd:Q26006 .

pl:Larkspur a owl:NamedIndividual , skos:Concept, :sacredPlant ;
  skos:inScheme sch:SacredThing ;
  skos:prefLabel "Larkspur"@en, "Pied d'alouette"@fr .

pl:Cypress a owl:NamedIndividual ,skos:Concept, :sacredPlant ;
  skos:inScheme sch:SacredThing ;
  skos:prefLabel "Cypress"@en, "Cyprès"@fr .

pl:OliveTree a owl:NamedIndividual ,skos:Concept, :sacredPlant ;
  skos:inScheme sch:SacredThing ;
  skos:prefLabel "OliveTree"@en, "Olivier"@fr .

pl:OakTree a owl:NamedIndividual ,skos:Concept, :sacredPlant ;
  skos:inScheme sch:SacredThing ;
  skos:prefLabel "OakTree"@en, "Chêne"@fr .
