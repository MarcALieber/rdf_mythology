@prefix : <http://www.semanticweb.org/ontologies/mythologies#> .
@prefix sch: <http://www.semanticweb.org/mythologies/scheme/> .
@prefix m: <http://www.semanticweb.org/mythologies/class#> .
@prefix p: <http://www.semanticweb.org/mythologies/property#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

:male rdf:type owl:NamedIndividual, skos:Concept;
  skos:prefLabel "male"@en ;
  skos:prefLabel "masculin"@fr .
  
:female rdf:type owl:NamedIndividual, skos:Concept;
  skos:prefLabel "female"@en ;
  skos:prefLabel "féminin"@fr .