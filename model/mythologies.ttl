###  http://www.semanticweb.org/ontologies/mythologies#Epimelides
:Epimelides rdf:type owl:Class ;
            rdfs:subClassOf :Nymph ;
            rdfs:seeAlso <https://www.wikidata.org/wiki/Q2006573> ,
                         "Epimeliads"@en ,
                         "Épimélides"@fr ;
            skos:definition "THE EPIMELIDES were nymphs of meadows and pastures--protectors of sheep flocks and guardians of fruit-trees. The name Epimelides was derived from the Greek words epi- \"protector\" and mêlon \"sheep\" or \"apple-tree.\"" ;
            skos:prefLabel "Epimelides"@en .


###  http://www.semanticweb.org/ontologies/mythologies#Erinyes
:Erinyes rdf:type owl:Class ;
         rdfs:subClassOf :OtherDeities ;
         rdfs:seeAlso <https://www.theoi.com/Khthonios/Erinyes.html> ;
         skos:altLabel "Furies"@en ;
         skos:definition "THE ERINYES (Furies) were three goddesses of vengeance and retribution who punished men for crimes against the natural order. They were particularly concerned with homicide, unfilial conduct, offenses against the gods, and perjury." ;
         skos:example "Alecto, Megaera, Tisiphone" ;
         skos:prefLabel "Erinyes"@en .


