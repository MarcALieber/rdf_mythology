@prefix : <http://www.semanticweb.org/ontologies/mythologies#> .
@prefix m: <http://www.semanticweb.org/mythologies/class#> .
@prefix p: <http://www.semanticweb.org/mythologies/property#> .
@prefix t: <http://www.semanticweb.org/mythologies/temple/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix geo: <http://www.semanticweb.org/mythologies/geography/> .
@prefix gim: <http://www.semanticweb.org/mythologies/greek/immortal/> .
@prefix gmo: <http://www.semanticweb.org/mythologies/greek/mortal/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rim: <http://www.semanticweb.org/mythologies/roman/immortal/> .
@prefix sch: <http://www.semanticweb.org/mythologies/scheme/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix auth: <http://www.semanticweb.org/mythologies/author/> .
@prefix city: <http://www.semanticweb.org/mythologies/greek/city/> .
@prefix myth: <http://www.semanticweb.org/mythologies/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix mytha: <http://www.semanticweb.org/mythologies/animal/> .
@prefix mythp: <http://www.semanticweb.org/mythologies/plant/> .
@base <http://www.semanticweb.org/ontologies/mythologies#> .

<http://www.semanticweb.org/ontologies/mythologie> rdf:type owl:Ontology ;
                                                    owl:imports <http://www.w3.org/2004/02/skos/core> ;
                                                    rdfs:comment "Mythologie grecque et romaine"@fr ;
                                                    owl:versionInfo 2.01 ;
                                                    skos:changeNote "23-01-2026 version 2.01 Draft; work in progress" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/mythologies/property#BornIn
p:BornIn rdf:type owl:ObjectProperty ;
         rdfs:domain :HumanNonhumanBeing ;
         rdfs:range :Geography ;
         skos:prefLabel "Born in"@en ,
                        "Né en"@fr .


###  http://www.semanticweb.org/mythologies/property#becomes
p:becomes rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf p:event .


###  http://www.semanticweb.org/mythologies/property#event
p:event rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/mythologies/property#hasChild
p:hasChild rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf p:isRelatedTo ;
           owl:inverseOf p:isChildOf ;
           rdfs:label "has child" .


###  http://www.semanticweb.org/mythologies/property#hasCounterpart
p:hasCounterpart rdf:type owl:ObjectProperty ;
                 skos:example "" .


###  http://www.semanticweb.org/mythologies/property#hasFather
p:hasFather rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf p:hasParent ;
            owl:inverseOf p:isFatherOf ;
            rdfs:label "has father" .


###  http://www.semanticweb.org/mythologies/property#hasFosterFather
p:hasFosterFather rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf p:hasParent ;
                  skos:prefLabel "a pour père adoptif"@fr ,
                                 "has Foster Father"@en .


###  http://www.semanticweb.org/mythologies/property#hasGender
p:hasGender rdf:type owl:ObjectProperty ;
            rdfs:domain :HumanNonhumanBeing ;
            rdfs:range :Gender .


###  http://www.semanticweb.org/mythologies/property#hasGreekCounterpart
p:hasGreekCounterpart rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf p:hasCounterpart ;
                      owl:inverseOf p:hasRomanCounterpart ;
                      skos:example "Cybele (Phrygian religion): the Greeks identified her with their own mother of the gods--the Titaness Rhea." .


###  http://www.semanticweb.org/mythologies/property#hasMother
p:hasMother rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf p:hasParent ;
            owl:inverseOf p:isMotherOf ;
            rdfs:label "has mother" .


###  http://www.semanticweb.org/mythologies/property#hasParent
p:hasParent rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :hasAncestor ;
            rdfs:label "has parent" .


###  http://www.semanticweb.org/mythologies/property#hasRomanCounterpart
p:hasRomanCounterpart rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf p:hasCounterpart .


###  http://www.semanticweb.org/mythologies/property#hasSourceIdentifier
p:hasSourceIdentifier rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/mythologies/property#hasSymbol
p:hasSymbol rdf:type owl:ObjectProperty ;
            rdfs:domain :Immortel ;
            rdfs:range :Symbol .


###  http://www.semanticweb.org/mythologies/property#hasTemple
p:hasTemple rdf:type owl:ObjectProperty ;
            rdfs:domain :HumanNonhumanBeing ;
            rdfs:range :Temple .


###  http://www.semanticweb.org/mythologies/property#isA
p:isA rdf:type owl:ObjectProperty ;
      rdfs:label "is a" .


###  http://www.semanticweb.org/mythologies/property#isAlsoCalled
p:isAlsoCalled rdf:type owl:ObjectProperty ;
               rdfs:label "is also called" .


###  http://www.semanticweb.org/mythologies/property#isBrotherOf
p:isBrotherOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf p:isSibling .


###  http://www.semanticweb.org/mythologies/property#isChildOf
p:isChildOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf p:isRelatedTo .


###  http://www.semanticweb.org/mythologies/property#isDaughterOf
p:isDaughterOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf p:isChildOf .


###  http://www.semanticweb.org/mythologies/property#isFatherOf
p:isFatherOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf p:hasChild .


###  http://www.semanticweb.org/mythologies/property#isFriendOf
p:isFriendOf rdf:type owl:ObjectProperty ,
                      owl:SymmetricProperty ;
             rdfs:domain :Mortals ;
             rdfs:range :Mortals ;
             rdfs:label "is friend of" .


###  http://www.semanticweb.org/mythologies/property#isGodOf
p:isGodOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Immortel .


###  http://www.semanticweb.org/mythologies/property#isGoddessOf
p:isGoddessOf rdf:type owl:ObjectProperty ;
              rdfs:domain :Immortel .


###  http://www.semanticweb.org/mythologies/property#isHusbandOf
p:isHusbandOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf p:isPartnerOf ;
              owl:inverseOf p:isSpouseOf ;
              rdfs:domain :HumanNonhumanBeing ;
              rdfs:range :HumanNonhumanBeing ;
              skos:prefLabel "is Husband of"@en .


###  http://www.semanticweb.org/mythologies/property#isKingOf
p:isKingOf rdf:type owl:ObjectProperty ;
           rdfs:domain :Mortals .


###  http://www.semanticweb.org/mythologies/property#isLocatedIn
p:isLocatedIn rdf:type owl:ObjectProperty ;
              rdfs:domain :Temple ;
              rdfs:range :Geography ;
              rdfs:label "is located in" .


###  http://www.semanticweb.org/mythologies/property#isLoverOf
p:isLoverOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf p:isPartnerOf ;
            rdf:type owl:SymmetricProperty ;
            rdfs:domain :HumanNonhumanBeing ;
            rdfs:range :HumanNonhumanBeing ;
            skos:prefLabel "est l'amant de"@fr ,
                           "is lover of"@en .


###  http://www.semanticweb.org/mythologies/property#isMotherOf
p:isMotherOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf p:hasChild .


###  http://www.semanticweb.org/mythologies/property#isPartnerOf
p:isPartnerOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf p:isRelatedTo ;
              rdfs:domain :HumanNonhumanBeing ;
              rdfs:range :HumanNonhumanBeing ;
              skos:prefLabel "is Partner of"@en .


###  http://www.semanticweb.org/mythologies/property#isRelatedTo
p:isRelatedTo rdf:type owl:ObjectProperty ;
              rdfs:domain :HumanNonhumanBeing ;
              rdfs:range :HumanNonhumanBeing ;
              rdfs:label "is related to" .


###  http://www.semanticweb.org/mythologies/property#isSibling
p:isSibling rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf p:isRelatedTo .


###  http://www.semanticweb.org/mythologies/property#isSisterOf
p:isSisterOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf p:isSibling .


###  http://www.semanticweb.org/mythologies/property#isSonOf
p:isSonOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf p:isChildOf .


###  http://www.semanticweb.org/mythologies/property#isSpouseOf
p:isSpouseOf rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf p:isPartnerOf ;
             rdfs:domain :HumanNonhumanBeing ;
             rdfs:range :HumanNonhumanBeing ;
             skos:prefLabel "is Spouse of"@en .


###  http://www.semanticweb.org/mythologies/property#isTempleOf
p:isTempleOf rdf:type owl:ObjectProperty ;
             rdfs:domain :Temple ;
             rdfs:range :HumanNonhumanBeing .


###  http://www.semanticweb.org/mythologies/property#isTwinBrotherOf
p:isTwinBrotherOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf p:isBrotherOf .


###  http://www.semanticweb.org/mythologies/property#isTwinSisterOf
p:isTwinSisterOf rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf p:isSisterOf .


###  http://www.semanticweb.org/mythologies/property#killedBy
p:killedBy rdf:type owl:ObjectProperty ;
           rdfs:domain :HumanNonhumanBeing ;
           rdfs:range :HumanNonhumanBeing ;
           rdfs:label "Killed by" .


###  http://www.semanticweb.org/mythologies/property#livesIn
p:livesIn rdf:type owl:ObjectProperty ;
          rdfs:domain :HumanNonhumanBeing ;
          rdfs:range :Geography ;
          skos:prefLabel "Lives in"@en .


###  http://www.semanticweb.org/mythologies/property#mentionedIn
p:mentionedIn rdf:type owl:ObjectProperty ;
              rdfs:label "mentioned in" .


###  http://www.semanticweb.org/mythologies/property#sacredAnimal
p:sacredAnimal rdf:type owl:ObjectProperty ;
               rdfs:domain :Immortel ;
               rdfs:range :MythicAnimals .


###  http://www.semanticweb.org/mythologies/property#sacredPlant
p:sacredPlant rdf:type owl:ObjectProperty ;
              rdfs:domain :Immortel ;
              rdfs:range :Plant .


###  http://www.semanticweb.org/mythologies/property#transformedInto
p:transformedInto rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf p:event .


###  http://www.semanticweb.org/mythologies/property#unmarriedPartner
p:unmarriedPartner rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf p:isPartnerOf ;
                   rdfs:domain :HumanNonhumanBeing ;
                   rdfs:range :HumanNonhumanBeing ;
                   skos:prefLabel "unmarried partner"@en .


###  http://www.semanticweb.org/mythologies/property#writtenBy
p:writtenBy rdf:type owl:ObjectProperty ;
            rdfs:domain :books ;
            rdfs:range :Author .


###  http://www.semanticweb.org/ontologies/mythologies#hasAncestor
:hasAncestor rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf p:isRelatedTo ;
             rdf:type owl:TransitiveProperty ;
             rdfs:domain :HumanNonhumanBeing ;
             rdfs:range :HumanNonhumanBeing .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/mythologies/property#godOf
p:godOf rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/mythologies/property#greekName
p:greekName rdf:type owl:DatatypeProperty ;
            rdfs:domain :HumanNonhumanBeing ;
            rdfs:range xsd:string .


###  http://www.semanticweb.org/mythologies/property#hasDBPediaSource
p:hasDBPediaSource rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf p:hasSource .


###  http://www.semanticweb.org/mythologies/property#hasOtherSource
p:hasOtherSource rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf p:hasSource .


###  http://www.semanticweb.org/mythologies/property#hasSource
p:hasSource rdf:type owl:DatatypeProperty ;
            rdfs:domain skos:Concept ;
            rdfs:range xsd:anyURI .


###  http://www.semanticweb.org/mythologies/property#hasTheoiSource
p:hasTheoiSource rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf p:hasSource .


###  http://www.semanticweb.org/mythologies/property#hasWikidataSource
p:hasWikidataSource rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf p:hasSource .


###  http://www.semanticweb.org/mythologies/property#image
p:image rdf:type owl:DatatypeProperty ;
        rdfs:comment "image" .


###  http://www.semanticweb.org/mythologies/property#nativeTerm
p:nativeTerm rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf owl:topDataProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "name in greek or Latin" .


###  http://www.semanticweb.org/mythologies/property#regular
p:regular rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf p:image ;
          rdfs:domain :HumanNonhumanBeing ;
          rdfs:range xsd:string .


###  http://www.semanticweb.org/mythologies/property#symbol
p:symbol rdf:type owl:DatatypeProperty ;
         rdfs:label "symbol" .


###  http://www.semanticweb.org/mythologies/property#thumbnail
p:thumbnail rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf p:image ;
            rdfs:domain :HumanNonhumanBeing ;
            rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/mythologies/scheme/AncienEgypt
sch:AncienEgypt rdf:type owl:Class ;
                rdfs:subClassOf sch:EgyptianWorld ;
                skos:example "Thebes, Akhenaton" .


###  http://www.semanticweb.org/mythologies/scheme/Argonauts
sch:Argonauts rdf:type owl:Class ;
              rdfs:subClassOf sch:GreekMythology ;
              rdfs:seeAlso <https://www.wikidata.org/wiki/Q165510> ;
              skos:definition "hero group in Greek mythology; Quest for the Golden Fleece"@en ;
              skos:prefLabel "Argonautes"@fr ,
                             "Argonauts"@en .


###  http://www.semanticweb.org/mythologies/scheme/Atreides
sch:Atreides rdf:type owl:Class ;
             rdfs:subClassOf sch:GreekMythology ;
             rdfs:label "Atreides"@en ;
             rdfs:seeAlso <https://www.wikidata.org/wiki/Q1932775> ;
             skos:definition "Atrides"@fr ,
                             "mythical descendants of Atreus" .


###  http://www.semanticweb.org/mythologies/scheme/ChristianMythology
sch:ChristianMythology rdf:type owl:Class ;
                       rdfs:subClassOf sch:mythology .


###  http://www.semanticweb.org/mythologies/scheme/EgyptianMythCharacter
sch:EgyptianMythCharacter rdf:type owl:Class ;
                          rdfs:subClassOf sch:MythCharacter .


###  http://www.semanticweb.org/mythologies/scheme/EgyptianMythology
sch:EgyptianMythology rdf:type owl:Class ;
                      rdfs:subClassOf sch:mythology .


###  http://www.semanticweb.org/mythologies/scheme/EgyptianWorld
sch:EgyptianWorld rdf:type owl:Class ;
                  rdfs:subClassOf sch:GeographicWorld .


###  http://www.semanticweb.org/mythologies/scheme/EtrusqueWorld
sch:EtrusqueWorld rdf:type owl:Class ;
                  rdfs:subClassOf sch:GeographicWorld .


###  http://www.semanticweb.org/mythologies/scheme/GeographicWorld
sch:GeographicWorld rdf:type owl:Class ;
                    rdfs:subClassOf skos:ConceptScheme .


###  http://www.semanticweb.org/mythologies/scheme/Greece
sch:Greece rdf:type owl:Class ;
           rdfs:subClassOf sch:GreekWorld ;
           skos:example "Athene, Sparte" .


###  http://www.semanticweb.org/mythologies/scheme/GreekAsia
sch:GreekAsia rdf:type owl:Class ;
              rdfs:subClassOf sch:GreekWorld .


###  http://www.semanticweb.org/mythologies/scheme/GreekItaly
sch:GreekItaly rdf:type owl:Class ;
               rdfs:subClassOf sch:GreekWorld ;
               skos:example "Naple,Marseille, Nice" .


###  http://www.semanticweb.org/mythologies/scheme/GreekMythCharacter
sch:GreekMythCharacter rdf:type owl:Class ;
                       rdfs:subClassOf sch:MythCharacter ;
                       rdfs:seeAlso <https://www.wikidata.org/wiki/Q22988604> ;
                       skos:prefLabel "mythological Greek character"@en ,
                                      "personnage de la mythologie grecque"@fr .


###  http://www.semanticweb.org/mythologies/scheme/GreekMythology
sch:GreekMythology rdf:type owl:Class ;
                   rdfs:subClassOf sch:mythology ;
                   rdfs:seeAlso <https://www.wikidata.org/wiki/Q34726> ;
                   skos:prefLabel "Greek mythology"@en ,
                                  "mythologie grecque"@fr .


###  http://www.semanticweb.org/mythologies/scheme/GreekSicile
sch:GreekSicile rdf:type owl:Class ;
                rdfs:subClassOf sch:GreekWorld .


###  http://www.semanticweb.org/mythologies/scheme/GreekWorld
sch:GreekWorld rdf:type owl:Class ;
               rdfs:subClassOf sch:GeographicWorld .


###  http://www.semanticweb.org/mythologies/scheme/Heracleidae
sch:Heracleidae rdf:type owl:Class ;
                rdfs:subClassOf sch:GreekMythology ;
                rdfs:seeAlso <https://www.wikidata.org/wiki/Q828084> ;
                skos:definition "mythical descendants of Heracles"@en ;
                skos:prefLabel "Heracleidae"@en ,
                               "Héraclides"@fr .


###  http://www.semanticweb.org/mythologies/scheme/IndianMythCharacter
sch:IndianMythCharacter rdf:type owl:Class ;
                        rdfs:subClassOf sch:MythCharacter .


###  http://www.semanticweb.org/mythologies/scheme/LegendOfTroy
sch:LegendOfTroy rdf:type owl:Class ;
                 rdfs:subClassOf sch:GreekMythology ;
                 rdfs:seeAlso <https://www.wikidata.org/wiki/Q22647> ;
                 skos:definition "stories and characters related to the city of Troy" ;
                 skos:prefLabel "Legend of Troy"@en ,
                                "Légende de Troie"@fr .


###  http://www.semanticweb.org/mythologies/scheme/LegendsOfHerakles
sch:LegendsOfHerakles rdf:type owl:Class ;
                      rdfs:subClassOf sch:GreekMythology ;
                      skos:prefLabel "Legends of Herakles"@en ,
                                     "légendes d'Hercule"@fr .


###  http://www.semanticweb.org/mythologies/scheme/MythCharacter
sch:MythCharacter rdf:type owl:Class ;
                  rdfs:subClassOf skos:ConceptScheme .


###  http://www.semanticweb.org/mythologies/scheme/NordicMythCharacter
sch:NordicMythCharacter rdf:type owl:Class ;
                        rdfs:subClassOf sch:MythCharacter .


###  http://www.semanticweb.org/mythologies/scheme/Odyssey
sch:Odyssey rdf:type owl:Class ;
            rdfs:subClassOf sch:GreekMythology ;
            rdfs:seeAlso <https://www.wikidata.org/wiki/Q35160> ;
            skos:definition "stories and characters related to Homer's Odyssey" ;
            skos:prefLabel "Odyssey"@en ,
                           "Odyssée"@fr .


###  http://www.semanticweb.org/mythologies/scheme/Oracle
sch:Oracle rdf:type owl:Class ;
           rdfs:subClassOf sch:SacredPlace ;
           skos:example "Delphes, Dodone" ;
           skos:prefLabel "Oracle"@en .


###  http://www.semanticweb.org/mythologies/scheme/OttomanEmpire
sch:OttomanEmpire rdf:type owl:Class ;
                  rdfs:subClassOf sch:GeographicWorld .


###  http://www.semanticweb.org/mythologies/scheme/PtolemianEgypt
sch:PtolemianEgypt rdf:type owl:Class ;
                   rdfs:subClassOf sch:EgyptianWorld ;
                   skos:example "Alexandrie, Alexandre," .


###  http://www.semanticweb.org/mythologies/scheme/RomanEgypt
sch:RomanEgypt rdf:type owl:Class ;
               rdfs:subClassOf sch:EgyptianWorld ;
               skos:example "Palmyre" .


###  http://www.semanticweb.org/mythologies/scheme/RomanEmpire
sch:RomanEmpire rdf:type owl:Class ;
                rdfs:subClassOf sch:GeographicWorld .


###  http://www.semanticweb.org/mythologies/scheme/RomanItaly
sch:RomanItaly rdf:type owl:Class ;
               rdfs:subClassOf sch:RomanEmpire .


###  http://www.semanticweb.org/mythologies/scheme/RomanMythCharacter
sch:RomanMythCharacter rdf:type owl:Class ;
                       rdfs:subClassOf sch:MythCharacter ;
                       rdfs:label "Roman Myth Character"@en .


###  http://www.semanticweb.org/mythologies/scheme/RomanMythology
sch:RomanMythology rdf:type owl:Class ;
                   rdfs:subClassOf sch:mythology ;
                   rdfs:seeAlso <https://www.wikidata.org/wiki/Q122173> ;
                   skos:definition "ensemble des légendes et des mythes de la Rome antique"@fr ,
                                   "traditional stories pertaining to ancient Rome's legendary origins and religious system"@en ;
                   skos:prefLabel "mythologie romaine"@fr ,
                                  "Roman mythology" .


###  http://www.semanticweb.org/mythologies/scheme/SacredPlace
sch:SacredPlace rdf:type owl:Class ;
                rdfs:subClassOf sch:SacredThing ;
                skos:example "Délos, temple de Dodone (Le parthenon n'est pas un temple sacré)" .


###  http://www.semanticweb.org/mythologies/scheme/SacredThing
sch:SacredThing rdf:type owl:Class ;
                rdfs:subClassOf skos:ConceptScheme .


###  http://www.semanticweb.org/mythologies/scheme/mythology
sch:mythology rdf:type owl:Class ;
              rdfs:subClassOf skos:ConceptScheme ;
              rdfs:seeAlso <https://www.wikidata.org/wiki/Q9134> ;
              skos:definition "collection of sacred stories or a set of beliefs belonging to a specific religious or cultural tradition. It is a system of narratives that typically explain the origin of the world, natural phenomena, human customs"@en ,
                              "ensemble de mythes liés à une civilisation, une religion ou un thème particulier"@fr ;
              skos:prefLabel "mythologie"@fr ,
                             "mythology"@en .


###  http://www.semanticweb.org/mythologies/scheme/mythologyOfCrete
sch:mythologyOfCrete rdf:type owl:Class ;
                     rdfs:subClassOf sch:GreekMythology ;
                     skos:prefLabel "Mythologie de l'ile de Crete"@fr ,
                                    "mythology of Crete"@en .


###  http://www.semanticweb.org/mythologies/scheme/mythologyOfThebes
sch:mythologyOfThebes rdf:type owl:Class ;
                      rdfs:subClassOf sch:GreekMythology ;
                      rdfs:seeAlso <https://www.wikidata.org/wiki/Q3974424> ;
                      skos:prefLabel "Thebeïade"@fr ,
                                     "mythology of Thebes"@en .


###  http://www.semanticweb.org/ontologies/mythologie#continent
:continent rdf:type owl:Class ;
           rdfs:subClassOf :Geography ;
           skos:example "Asie, Europe,afrique" .


###  http://www.semanticweb.org/ontologies/mythologie#country
:country rdf:type owl:Class ;
         rdfs:subClassOf :Geography .


###  http://www.semanticweb.org/ontologies/mythologie#philosophe
:philosophe rdf:type owl:Class ;
            rdfs:subClassOf :Author .


###  http://www.semanticweb.org/ontologies/mythologie#sea
:sea rdf:type owl:Class ;
     rdfs:subClassOf :Geography ;
     skos:example """mer medterranée
Ocean atlantique
Les Néreides vivent en méditerranée""" .


###  http://www.semanticweb.org/ontologies/mythologies#AgriculturalDeities
:AgriculturalDeities rdf:type owl:Class ;
                     rdfs:subClassOf :NatureDeities ;
                     skos:example "Priapus" ;
                     skos:prefLabel "Deité agricole"@fr ,
                                    "Agricultural Deities" .


###  http://www.semanticweb.org/ontologies/mythologies#Amazon
:Amazon rdf:type owl:Class ;
        rdfs:subClassOf :Mortals .


###  http://www.semanticweb.org/ontologies/mythologies#Attribute
